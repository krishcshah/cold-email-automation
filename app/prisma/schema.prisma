// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth & Users ───────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  emailAccounts        EmailAccount[]
  leadLists            LeadList[]
  campaigns            Campaign[]
  snippets             Snippet[]
  suppressionEntries   SuppressionEntry[]
  linkedInAccounts     LinkedInAccount[]
  twilioAccount        TwilioAccount?
  contacts             Contact[]
  tags                 Tag[]
  activityLogs         ActivityLog[]
  prospectSearchLogs   ProspectSearchLog[]
  apiKeys              ApiKey[]
  webhookSubscriptions WebhookSubscription[]
  integrationSettings  IntegrationSetting[]
  workspaces           Workspace[]
}

// ─── Email Accounts ──────────────────────────────────────────────────────────

model EmailAccount {
  id       String        @id @default(cuid())
  userId   String
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  fromName  String
  fromEmail String

  // SMTP
  smtpHost String
  smtpPort Int
  smtpUser String
  smtpPass String  // AES-256 encrypted

  // IMAP
  imapHost String?
  imapPort Int?
  imapUser String?
  imapPass String?  // AES-256 encrypted

  // Custom Tracking Domain
  customDomain String?

  status      AccountStatus @default(untested)
  lastTestedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaignSenders CampaignSender[]
  emailEvents     EmailEvent[]
  inboxReplies    InboxReply[]
  warmupSetting   WarmupSetting?
  warmupLogs      WarmupLog[]
}

enum AccountStatus {
  active
  error
  untested
}

// ─── Lead Lists ───────────────────────────────────────────────────────────────

model LeadList {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leads             Lead[]
  campaignLeadLists CampaignLeadList[]
}

model Lead {
  id         String    @id @default(cuid())
  leadListId String
  leadList   LeadList  @relation(fields: [leadListId], references: [id], onDelete: Cascade)

  email      String
  firstName  String?
  lastName   String?
  company    String?
  title      String?
  phone      String?
  website    String?
  customFields Json?   // { "any_custom_col": "value" }

  status     LeadStatus @default(active)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  leadCampaignStates LeadCampaignState[]
  emailEvents        EmailEvent[]
  inboxReplies       InboxReply[]
  unsubscribeTokens  UnsubscribeToken[]
  contact            Contact?
}

enum LeadStatus {
  active
  unsubscribed
  bounced
  replied
}

// ─── Campaigns ────────────────────────────────────────────────────────────────

model Campaign {
  id     String         @id @default(cuid())
  userId String
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name   String
  status CampaignStatus @default(draft)

  // Sending settings stored as JSON for flexibility
  dailyLimit    Int     @default(50)    // per sender account
  minDelaySecs  Int     @default(60)    // randomized delay between sends
  maxDelaySecs  Int     @default(180)
  sendDays      String  @default("1,2,3,4,5") // Mon=1 ... Sun=7, CSV
  sendStartHour Int     @default(9)
  sendEndHour   Int     @default(17)
  timezone      String  @default("UTC")
  trackOpens    Boolean @default(true)
  trackClicks   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sequenceSteps      SequenceStep[]
  campaignLeadLists  CampaignLeadList[]
  campaignSenders    CampaignSender[]
  emailEvents        EmailEvent[]
  leadCampaignStates LeadCampaignState[]
  inboxReplies       InboxReply[]
}

enum CampaignStatus {
  draft
  active
  paused
  stopped
  completed
}

model SequenceStep {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  stepNumber  Int
  subject     String
  body        String   @db.Text
  delayDays   Int      @default(0)  // 0 = send immediately (first step)

  // Multichannel: "email" | "linkedin_connect" | "linkedin_message" | "linkedin_view" | "sms" | "call_task"
  channel     String   @default("email")

  // Advanced Branching: "always" | "if_opened" | "if_not_opened" | "if_clicked"
  condition   String   @default("always")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  variants    SequenceStepVariant[]

  @@unique([campaignId, stepNumber])
}

model SequenceStepVariant {
  id         String       @id @default(cuid())
  stepId     String
  step       SequenceStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  variantLetter String   @default("A") // "A", "B", etc.
  subject       String
  body          String   @db.Text
  sentCount     Int      @default(0)
  openCount     Int      @default(0)
  clickCount    Int      @default(0)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model CampaignLeadList {
  campaignId String
  leadListId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  leadList   LeadList @relation(fields: [leadListId], references: [id], onDelete: Cascade)

  @@id([campaignId, leadListId])
}

model CampaignSender {
  campaignId     String
  emailAccountId String
  campaign       Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  emailAccount   EmailAccount @relation(fields: [emailAccountId], references: [id], onDelete: Cascade)

  @@id([campaignId, emailAccountId])
}

// ─── Email Events & State ─────────────────────────────────────────────────────

model LeadCampaignState {
  id           String     @id @default(cuid())
  campaignId   String
  leadId       String
  campaign     Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead         Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)

  currentStep     Int                @default(1)
  status          LeadCampaignStatus @default(active)
  resumeAt        DateTime?          // For OOO auto-pause resume
  lastEmailSentAt DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([campaignId, leadId])
}

enum LeadCampaignStatus {
  active
  replied
  unsubscribed
  bounced
  completed
  paused_ooo
}

model EmailEvent {
  id             String         @id @default(cuid())
  campaignId     String
  leadId         String
  emailAccountId String
  stepNumber     Int
  type           EmailEventType
  occurredAt     DateTime       @default(now())
  metadata       Json?          // { url, messageId, ... }

  // Tracking tokens
  openToken  String? @unique
  clickToken String? @unique

  campaign     Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead         Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  emailAccount EmailAccount @relation(fields: [emailAccountId], references: [id], onDelete: Cascade)
}

enum EmailEventType {
  sent
  opened
  clicked
  replied
  bounced
  unsubscribed
  sms_sent
  linkedin_action
  call_task
}

// ─── Inbox ────────────────────────────────────────────────────────────────────

model InboxReply {
  id             String      @id @default(cuid())
  campaignId     String
  leadId         String
  emailAccountId String
  subject        String?
  bodyText       String?     @db.Text
  bodyHtml       String?     @db.Text
  receivedAt     DateTime    @default(now())
  label          InboxLabel  @default(none)
  isRead         Boolean     @default(false)
  repliedAt      DateTime?
  messageId      String?     // the email Message-ID header
  inReplyTo      String?     // In-Reply-To header for matching

  campaign     Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead         Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  emailAccount EmailAccount @relation(fields: [emailAccountId], references: [id], onDelete: Cascade)
}

enum InboxLabel {
  none
  interested
  not_interested
  meeting_booked
  unsubscribed
  ooo
}

// ─── Unsubscribe ──────────────────────────────────────────────────────────────

model UnsubscribeToken {
  id         String    @id @default(cuid())
  token      String    @unique @default(cuid())
  leadId     String
  campaignId String
  lead       Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  usedAt     DateTime?
  createdAt  DateTime  @default(now())
}

// ─── Warmup System ────────────────────────────────────────────────────────────

model WarmupSetting {
  id             String       @id @default(cuid())
  emailAccountId String       @unique
  emailAccount   EmailAccount @relation(fields: [emailAccountId], references: [id], onDelete: Cascade)

  enabled        Boolean  @default(false)
  dailyLimit     Int      @default(40)       // Target max warmup emails/day
  rampUpDays     Int      @default(30)       // Days to reach target
  rampUpCurve    String   @default("linear") // "linear" | "exponential"
  replyRate      Int      @default(35)       // Target reply % (0-100)
  importantRate  Int      @default(20)       // % to mark as important
  spamRescueRate Int      @default(15)       // % to rescue from spam

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WarmupLog {
  id             String       @id @default(cuid())
  emailAccountId String
  emailAccount   EmailAccount @relation(fields: [emailAccountId], references: [id], onDelete: Cascade)

  peerAccountId String?
  peerEmail     String?
  action        WarmupAction
  status        String       @default("success")
  occurredAt    DateTime     @default(now())
}

enum WarmupAction {
  sent_warmup
  received_warmup
  replied_warmup
  marked_important
  rescued_from_spam
}

// ─── Deliverability & Domain Health ─────────────────────────────────────────

model DomainHealth {
  id          String   @id @default(cuid())
  domain      String   @unique
  spfValid    Boolean  @default(false)
  dkimValid   Boolean  @default(false)
  dmarcValid  Boolean  @default(false)
  spfRecord   String?
  dmarcRecord String?
  blacklisted Boolean  @default(false)
  blacklistDetails Json?
  lastCheckedAt DateTime @default(now())
}

// ─── Snippets & Suppression ─────────────────────────────────────────────────

model Snippet {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String   // e.g. "calendar_link", "case_study"
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
}

model SuppressionEntry {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      SuppressionType @default(email) // "email" | "domain"
  value     String          // e.g. "competitor.com" or "john@unwanted.com"
  reason    String?
  createdAt DateTime        @default(now())

  @@unique([userId, value])
}

enum SuppressionType {
  email
  domain
}

// ─── Multichannel Accounts ───────────────────────────────────────────────────

model LinkedInAccount {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileName  String
  profileUrl   String?
  liAtCookie   String   // Encrypted session cookie
  dailyLimit   Int      @default(20)
  sentToday    Int      @default(0)
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TwilioAccount {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountSid  String
  authToken   String   // Encrypted
  phoneNumber String
  status      String   @default("active")
  createdAt   DateTime @default(now())
}

// ─── Built-in CRM (Contacts, Kanban, Notes, Call Queue) ─────────────────────

enum PipelineStage {
  new_lead
  contacted
  interested
  meeting_booked
  closed_won
  closed_lost
}

model Contact {
  id         String        @id @default(cuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadId     String?       @unique
  lead       Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)

  email      String
  firstName  String?
  lastName   String?
  company    String?
  title      String?
  phone      String?
  stage      PipelineStage @default(new_lead)
  dealValue  Float         @default(0)

  assignedToId String?     // Workspace member name/id

  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  contactTags ContactTag[]
  notes       ContactNote[]
  tasks       ContactTask[]
  callLogs    CallLog[]
}

model Tag {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  color     String       @default("#10b981")
  createdAt DateTime     @default(now())

  contactTags ContactTag[]
  @@unique([userId, name])
}

model ContactTag {
  contactId String
  tagId     String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
}

model ContactNote {
  id         String   @id @default(cuid())
  contactId  String
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  authorName String
  content    String   @db.Text
  createdAt  DateTime @default(now())
}

model ContactTask {
  id        String    @id @default(cuid())
  contactId String
  contact   Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  title     String
  dueDate   DateTime?
  completed Boolean   @default(false)
  createdAt DateTime  @default(now())
}

model CallLog {
  id           String   @id @default(cuid())
  contactId    String
  contact      Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  outcome      String   // "connected" | "voicemail" | "no_answer"
  notes        String?  @db.Text
  loggedByName String
  createdAt    DateTime @default(now())
}

// ─── Team Collaboration ──────────────────────────────────────────────────────

enum WorkspaceRole {
  admin
  member
  viewer
}

model WorkspaceMember {
  id        String        @id @default(cuid())
  ownerId   String        // Workspace owner User ID
  email     String
  name      String?
  role      WorkspaceRole @default(member)
  status    String        @default("invited")
  createdAt DateTime      @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String   // Workspace owner
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  actorName String
  action    String   // e.g. "Moved deal to Closed Won", "Logged call with John"
  target    String?
  createdAt DateTime @default(now())
}

// ─── Prospecting & Enrichment ─────────────────────────────────────────────

model ProspectSearchLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  query     Json
  results   Int      @default(0)
  createdAt DateTime @default(now())
}

// ─── API Keys & Webhook Dispatcher ──────────────────────────────────────────

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  key        String    @unique
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
}

model WebhookSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url       String
  events    String   // CSV e.g. "email.sent,email.replied,meeting.booked"
  secret    String
  status    String   @default("active")
  createdAt DateTime @default(now())
}

// ─── Native Integrations Settings ──────────────────────────────────────────

model IntegrationSetting {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider    String   // "hubspot" | "pipedrive" | "salesforce" | "slack" | "sheets"
  apiKey      String?
  accessToken String?
  config      Json?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, provider])
}

// ─── Workspaces & Agency Mode ────────────────────────────────────────────────

model Workspace {
  id                     String   @id @default(cuid())
  ownerId                String
  owner                  User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name                   String
  slug                   String   @unique
  clientName             String?
  clientEmail            String?
  sendingCreditsLimit    Int      @default(10000)
  sendingCreditsUsed     Int      @default(0)
  enrichmentCreditsLimit Int      @default(500)
  enrichmentCreditsUsed  Int      @default(0)
  isAgencyMaster         Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  whiteLabelSetting WhiteLabelSetting?
  auditLogs         AuditLog[]
  ipAllowlists      IpAllowlist[]
  shareableReports  ShareableReport[]
}

model WhiteLabelSetting {
  id             String    @id @default(cuid())
  workspaceId    String    @unique
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customDomain   String?   @unique
  companyName    String?   @default("OutreachPro")
  logoUrl        String?
  faviconUrl     String?
  primaryColor   String?   @default("#0284c7")
  supportEmail   String?
  removeBranding Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ─── Shareable Client Reports ────────────────────────────────────────────────

model ShareableReport {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  token       String    @unique @default(cuid())
  title       String
  campaignIds String    // CSV of campaign IDs
  views       Int       @default(0)
  createdAt   DateTime  @default(now())
}

// ─── Enterprise Security & Audit Log ───────────────────────────────────────

model AuditLog {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actorName   String
  actorEmail  String
  ipAddress   String?
  actionType  String
  details     String?   @db.Text
  createdAt   DateTime  @default(now())
}

model IpAllowlist {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ipAddress   String
  label       String?
  createdAt   DateTime  @default(now())

  @@unique([workspaceId, ipAddress])
}
